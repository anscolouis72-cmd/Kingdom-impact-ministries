# Email Configuration
# For Gmail: Use your Gmail address and an App Password (if 2FA enabled)
# To generate App Password: https://myaccount.google.com/apppasswords

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# For development, you can use any email service supported by nodemailer
# Common options: gmail, outlook, yahoo, sendgrid, or custom SMTP server

# When running on a real Android device, set this to your computer's local IP address
# Example: VITE_API_BASE_URL=http://192.168.0.100:5000
VITE_API_BASE_URL=http://localhost:5000
